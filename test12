local function getJoinCode()
    local player = game:GetService("Players").LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui")
    local privatserverInfo = playerGui:FindFirstChild("Privatserver_Info")
    
    if not privatserverInfo then return "Error: GUI not found" end
    
    local joinCodeLabel = privatserverInfo:FindFirstChild("PrivatserverInfo")
        and privatserverInfo.PrivatserverInfo:FindFirstChild("Body")
        and privatserverInfo.PrivatserverInfo.Body:FindFirstChild("ServerInfo")
        and privatserverInfo.PrivatserverInfo.Body.ServerInfo:FindFirstChild("JoinCode")
    
    if joinCodeLabel then
        return joinCodeLabel.Text
    end
    return "Error: JoinCode not found"
end

