local PlaceID    = game.PlaceId
local HOP_FILE = "ServerHop_" .. tostring(LocalPlayer.UserId) .. ".json"
local ServerList = {}

pcall(function() ServerList = HttpService:JSONDecode(readfile(HOP_FILE)) end)
if type(ServerList) ~= "table" then ServerList = {} end
if #ServerList >= 5 then
    ServerList = {}
    writefile(HOP_FILE, HttpService:JSONEncode(ServerList))
end

local function hopToNewServer()
    print("[ServerHop] Fetching server list...")
    pauseRuntime()

    local function tryHop(cursor)
        local url = "https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Desc&limit=100"
        if cursor ~= "" then url = url .. "&cursor=" .. cursor end

        local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
        if not ok or not result or not result.data then
            warn("[ServerHop] Failed to fetch server list, retrying in 5s...")
            task.wait(5)
            return tryHop("")
        end

        for _, server in pairs(result.data) do
            local id = tostring(server.id)
            if server.playing >= server.maxPlayers then continue end
            local skip = false
            for _, v in pairs(ServerList) do
                if v == id then skip = true break end
            end
            if not skip then
                table.insert(ServerList, id)
                writefile(HOP_FILE, HttpService:JSONEncode(ServerList))
                print("[ServerHop] Hopping to new server...")
                local teleOk = pcall(function()
                    TeleportService:TeleportToPlaceInstance(PlaceID, id, LocalPlayer)
                end)
                if teleOk then
                    task.wait(5)
                    print("[ServerHop] Teleport may have failed, trying next server...")
                end
            end
        end

        local next = result.nextPageCursor
        if next and next ~= "" then return tryHop(next) end

        print("[ServerHop] All servers visited or full, clearing list and retrying...")
        ServerList = {}
        writefile(HOP_FILE, HttpService:JSONEncode(ServerList))
        task.wait(3)
        return tryHop("")
    end

    tryHop("")
end

