local IMAGE_TO_TOOLNAME = {}
for toolName, imgId in pairs(ITEM_IMAGES) do
    IMAGE_TO_TOOLNAME[imgId] = toolName
end

local DROPDOWN_OPTIONS = {}
for toolName, _ in pairs(ITEM_IMAGES) do
    table.insert(DROPDOWN_OPTIONS, toolName)
end
table.sort(DROPDOWN_OPTIONS)

local selectedItemTypes = {}
for _, v in ipairs(DROPDOWN_OPTIONS) do
    selectedItemTypes[v] = true
end

local function getSelectedToolNames()
    local names = {}
    local seen  = {}
    pcall(function()
        local scroll = LocalPlayer.PlayerGui
            .DanymicToolBar_2.Main.Backpack.Backback_image.Backpack_scroll
        for _, v in ipairs(scroll:GetChildren()) do
            if v:IsA("TextButton") and not seen[v.Name] then
                local img = v:FindFirstChild("Image")
                if img then
                    local toolName = IMAGE_TO_TOOLNAME[img.Image]
                    if toolName and selectedItemTypes[toolName] then
                        seen[v.Name] = true
                        table.insert(names, v.Name)
                    end
                end
            end
        end
    end)
    return names
end

local function giveAllPackagesToPlayer(target)
    local names = getSelectedToolNames()
    if #names == 0 then
        print("[Give] No matching items found in backpack.")
        return 0
    end

    local sent     = 0
    local backpack = LocalPlayer:WaitForChild("Backpack")
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

    local i = 1
    while i <= #names and giveRunning do
        local batch = {}
        for slot = 2, 9 do
            if i > #names then break end
            local name = names[i]
            pcall(function()
                dataRemote:FireServer({ { KevArgs = { name, slot } }, realByte })
            end)
            table.insert(batch, name)
            i += 1
            task.wait(0.03)
        end
        task.wait(0.2)

        for _, toolName in ipairs(batch) do
            if not giveRunning then break end
            local tool = backpack:FindFirstChild(toolName)
            if tool and humanoid then
                pcall(function() humanoid:EquipTool(tool) end)
                task.wait(0.1)
                local equippedTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(toolName)
                local toolRef = equippedTool or tool
                local toolId  = toolRef:GetAttribute("ToolId")
                    or toolRef:GetAttribute("ID")
                    or toolRef:GetAttribute("id")
                    or toolRef.Name
                pcall(function()
                    giveRemote:InvokeServer(tostring(toolId), target)
                end)
                sent += 1
                task.wait(0.1)
            end
        end
    end

    pcall(function()
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:UnequipTools() end
    end)

    return sent
end

local function giveLoop()
    while giveRunning do
        local target = findPlayerByPartialName(giveTargetName)
        if not target then
            print("[Give] Player not found: " .. giveTargetName)
            task.wait(2)
        else
            local sent = giveAllPackagesToPlayer(target)
            if sent > 0 then
                print(string.format("[Give] Sent %d items to %s", sent, target.Name))
            end
            task.wait(1)
        end
    end
end

