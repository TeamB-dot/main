local farmRunning     = false
local farmThread      = nil
local currentPlatform = nil

local function waitForCharacter()
    local char = workspace:WaitForChild("Characters"):WaitForChild(LocalPlayer.Name)
    local hrp  = char:WaitForChild("HumanoidRootPart")
    return char, hrp
end

local function teleportTo(pos)
    local _, hrp = waitForCharacter()
    hrp.CFrame = CFrame.new(pos)
    task.wait(0.1)
    local char    = LocalPlayer.Character
    local hum     = char and char:FindFirstChildOfClass("Humanoid")
    local timeout = os.clock() + 2
    while hum and hum.FloorMaterial == Enum.Material.Air and os.clock() < timeout do
        task.wait(0.05)
    end
end

local function spawnNewPlatform(x, y, z)
    if currentPlatform and currentPlatform.Parent then
        currentPlatform:Destroy()
        currentPlatform = nil
    end
    local platform        = Instance.new("Part")
    platform.Name         = "FarmPlatform"
    platform.Size         = PLATFORM_SIZE
    platform.CFrame       = CFrame.new(x, y, z)
    platform.Anchored     = true
    platform.CanCollide   = true
    platform.BrickColor   = BrickColor.new("Bright red")
    platform.Transparency = 0.4
    platform.Parent       = workspace
    currentPlatform       = platform
    return platform
end

local function findNearestPackstation(playerPos)
    local folder = workspace:FindFirstChild("NEUE_MAP_STUCTURE")
    folder = folder and folder:FindFirstChild("Props")
    folder = folder and folder:FindFirstChild("PackstationProps")
    if not folder then warn("[Farm] PackstationProps folder not found.") return nil end

    local nearest, nearestDist = nil, math.huge
    for _, outer in ipairs(folder:GetChildren()) do
        if outer.Name == "Packstation" then
            for _, inner in ipairs(outer:GetChildren()) do
                if inner.Name == "Packstation" and inner:IsA("Model") then
                    for _, obj in ipairs(inner:GetChildren()) do
                        if obj:IsA("BasePart") and (obj.Name == "Door" or obj.Name:match("^Door%d+$")) then
                            local dist = (playerPos - obj.Position).Magnitude
                            if dist < nearestDist then
                                nearestDist = dist
                                nearest     = inner
                            end
                            break
                        end
                    end
                end
            end
        end
    end
    if not nearest then warn("[Farm] No packstation found.") end
    return nearest
end

local function getModelBottomY(model)
    local lowestY = math.huge
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            local y = part.Position.Y - (part.Size.Y / 2)
            if y < lowestY then lowestY = y end
        end
    end
    return lowestY
end

local function spawnPlatformAndTP(packstation)
    local bottomY   = getModelBottomY(packstation)
    local centerCF  = packstation:GetModelCFrame()
    local platformY = bottomY - PLATFORM_BELOW_Y
    spawnNewPlatform(centerCF.Position.X, platformY, centerCF.Position.Z)
    task.wait(0.05)
    teleportTo(Vector3.new(centerCF.Position.X, platformY + (PLATFORM_SIZE.Y / 2) + 3, centerCF.Position.Z))
end

local function findConcreteDrill()
    for _, tool in ipairs(LocalPlayer:WaitForChild("Backpack"):GetChildren()) do
        if tool:IsA("Tool") and tool:GetAttribute("ToolName") == "ConcreteDrill" then return tool end
    end
    warn("[Farm] ConcreteDrill not found.")
    return nil
end

local function findRemoteEvent(drillTool)
    local re = drillTool:FindFirstChild("OnBohrerTriggered")
    if re then return re end
    local char = workspace.Characters:FindFirstChild(LocalPlayer.Name)
    if char then
        for _, child in ipairs(char:GetChildren()) do
            local found = child:FindFirstChild("OnBohrerTriggered")
            if found then return found end
        end
    end
    warn("[Farm] RemoteEvent not found.")
    return nil
end

local function collectNearbyPackages(centerPos)
    local ignoreFolder = workspace:FindFirstChild("Ignore")
    if not ignoreFolder then return end

    for _, model in ipairs(ignoreFolder:GetChildren()) do
        if not farmRunning then break end
        if model:IsA("Model") and model:GetAttribute("ToolName") == "SmallPackage" then
            local part = model.PrimaryPart
            if not part then
                for _, c in ipairs(model:GetDescendants()) do
                    if c:IsA("BasePart") then part = c break end
                end
            end
            if part and (centerPos - part.Position).Magnitude <= PACKAGE_RADIUS then
                for _, c in ipairs(model:GetDescendants()) do
                    if c:IsA("BasePart") then c.CanCollide = false end
                end
                local _, hrp = waitForCharacter()
                if model.PrimaryPart then
                    model:SetPrimaryPartCFrame(hrp.CFrame)
                else
                    part.CFrame = hrp.CFrame
                end
                task.wait(0.03)
                local handle = model:FindFirstChild("Handle")
                if handle then
                    local proxy = handle:FindFirstChild("proxy")
                    if proxy and proxy:IsA("ProximityPrompt") then
                        fireproximityprompt(proxy)
                    end
                end
                task.wait(COLLECT_DELAY)
            end
        end
    end
end

local function drillAllDoors(packstation, hrp)
    local drillTool = findConcreteDrill()
    if not drillTool then return end
    local remoteEvent = findRemoteEvent(drillTool)
    if not remoteEvent then return end

    local allDoors = {}
    for _, obj in ipairs(packstation:GetChildren()) do
        if obj.Name == "Door" and obj:IsA("BasePart") then
            table.insert(allDoors, obj)
        end
    end
    if #allDoors == 0 then warn("[Farm] No doors found.") return end
    for i, door in ipairs(allDoors) do door.Name = "Door" .. i end

    for i, door in ipairs(allDoors) do
        if not farmRunning then break end
        if door:GetAttribute("IsOpen") == true then
            collectNearbyPackages(hrp.Position)
        else
            print(string.format("[Farm] Drilling Door%d...", i))
            local opened   = false
            local attempts = 0
            while not opened and farmRunning do
                attempts += 1
                pcall(function() remoteEvent:FireServer(door) end)
                task.wait(DRILL_WAIT)
                if door:GetAttribute("IsOpen") == true then
                    opened = true
                    task.wait(0.15)
                    collectNearbyPackages(hrp.Position)
                else
                    pcall(function() remoteEvent:FireServer(door) end)
                    task.wait(DRILL_WAIT)
                    if door:GetAttribute("IsOpen") == true then
                        opened = true
                        task.wait(0.15)
                        collectNearbyPackages(hrp.Position)
                    end
                end
                if not opened and attempts % 8 == 0 then
                    print(string.format("[Farm] Door%d still not open after %d attempts, re-loading...", i, attempts * 2))
                    teleportTo(hrp.Position)
                end
            end
        end
    end
end

local function farmLoop()
    for i, stationPos in ipairs(PACKSTATION_POSITIONS) do
        if not farmRunning then break end
        print(string.format("[Farm] Station %d / %d", i, #PACKSTATION_POSITIONS))
        teleportTo(stationPos)
        local _, hrp = waitForCharacter()

        local packstation = findNearestPackstation(hrp.Position)
        if packstation then
            spawnPlatformAndTP(packstation)
            local _, hrp2 = waitForCharacter()
            drillAllDoors(packstation, hrp2)
            task.wait(0.3)
            local _, hrp3 = waitForCharacter()
            collectNearbyPackages(hrp3.Position)
            task.wait(0.05)
        end
        task.wait(0.5)
    end

    if farmRunning then
        print("[Farm] All stations done, hopping server...")
        local _, hrp = waitForCharacter()
        hrp.CFrame = CFrame.new(HOP_POSITION)
        task.wait(0.5)
        hopToNewServer()
    end
end

