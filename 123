local autoOpenRunning = false
local autoOpenThread  = nil

local identifierStorage = ReplicatedStorage
    :WaitForChild("BridgeNet2")
    :WaitForChild("identifierStorage")

local realByte   = identifierStorage:GetAttribute("RemoteEvent_AddItemToToolbar")
local dataRemote = ReplicatedStorage:WaitForChild("BridgeNet2"):WaitForChild("dataRemoteEvent")

local function getAllPackageNames()
    local names = {}
    local seen  = {}
    pcall(function()
        local scroll = LocalPlayer.PlayerGui
            .DanymicToolBar_2.Main.Backpack.Backback_image.Backpack_scroll
        for _, v in ipairs(scroll:GetChildren()) do
            if v:IsA("TextButton") then
                local img = v:FindFirstChild("Image")
                if img and img.Image == "rbxassetid://17498817945" then
                    if not seen[v.Name] then
                        seen[v.Name] = true
                        table.insert(names, v.Name)
                    end
                end
            end
        end
    end)
    return names
end

local function fillToolbar()
    local names  = getAllPackageNames()
    local filled = {}
    for i, name in ipairs(names) do
        local slot = i + 1
        if slot > 9 then break end
        pcall(function()
            dataRemote:FireServer({ { KevArgs = { name, slot } }, realByte })
        end)
        table.insert(filled, name)
        task.wait(0.03)
    end
    return filled
end

local function openFilledTools(filledNames)
    local backpack = LocalPlayer:WaitForChild("Backpack")
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    for _, toolName in ipairs(filledNames) do
        if not autoOpenRunning then break end
        local tool = backpack:FindFirstChild(toolName)
            or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(toolName))
        if tool then
            pcall(function() humanoid:EquipTool(tool) end)
            task.wait(0.1)
            local remote = tool:FindFirstChild("OnOpenRemoteEvent")
            if remote then
                for _ = 1, 3 do
                    pcall(function() remote:FireServer() end)
                    task.wait(0.08)
                end
            end
            task.wait(0.1)
        end
    end
    pcall(function() humanoid:UnequipTools() end)
end

local function autoOpenLoop()
    while autoOpenRunning do
        local names = getAllPackageNames()
        if #names == 0 then
            print("[AutoOpen] No more packages.")
            autoOpenRunning = false
            break
        end
        print(string.format("[AutoOpen] Found %d packages, filling slots 2-%d...", #names, math.min(#names + 1, 8)))
        local filled = fillToolbar()
        task.wait(0.2)
        openFilledTools(filled)
        task.wait(0.1)
    end
    print("[AutoOpen] Done.")
end

