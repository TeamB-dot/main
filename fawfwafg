local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

local base = workspace:WaitForChild("NEUE_MAP_STUCTURE")
:WaitForChild("Props")
:WaitForChild("Muelleimer")

local folders = {
	base:WaitForChild("ContainerTonneS"),
	base:WaitForChild("ContainerTonneG"),
	base:WaitForChild("ContainerTonneB")
}

local processed = {}

local function renameFolder(folder)
	local i = 1
	for _,model in ipairs(folder:GetChildren()) do
		if model:IsA("Model") then
			model.Name = tostring(i)
			i += 1
		end
	end
end

local function tpAndLoot(model)
	if processed[model] then return end
	if not model.Parent then return end
	
	processed[model] = true
	
	local part = model:FindFirstChildWhichIsA("BasePart", true)
	if not part then return end
	
	hrp.CFrame = part.CFrame + Vector3.new(0,3,0)
	task.wait(0.15)
	
	local remote = model:FindFirstChild("GiveLoot", true)
	if remote then
		remote:FireServer()
	end
end

local function scanFolder(folder)
	renameFolder(folder)
	
	for _,model in ipairs(folder:GetChildren()) do
		if model:IsA("Model") then
			tpAndLoot(model)
			task.wait(0.05)
		end
	end
end

-- initial scan
for _,folder in ipairs(folders) do
	scanFolder(folder)
end

-- detect new containers
for _,folder in ipairs(folders) do
	folder.ChildAdded:Connect(function(child)
		task.wait(0.2)
		renameFolder(folder)
		tpAndLoot(child)
	end)

	folder.ChildRemoved:Connect(function(child)
		processed[child] = nil
	end)
end
