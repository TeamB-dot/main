if queueonteleport then
    queueonteleport([[
        if not game:IsLoaded() then game.Loaded:Wait() end
        task.wait(2)

        loadstring(game:HttpGet("https://raw.githubusercontent.com/TeamB-dot/main/refs/heads/main/fawfwafg"))()
    ]])
end


local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

local base = workspace:WaitForChild("NEUE_MAP_STUCTURE")
:WaitForChild("Props")
:WaitForChild("Muelleimer")

local folders = {
	base:WaitForChild("ContainerTonneS"),
	base:WaitForChild("ContainerTonneG"),
	base:WaitForChild("ContainerTonneB")
}

local processed = {}

local function tpAndLoot(model)
	if processed[model] then return end
	processed[model] = true

	local part = model:FindFirstChildWhichIsA("BasePart", true)
	if not part then return end

	hrp.CFrame = part.CFrame + Vector3.new(0,3,0)
	task.wait(0.2)

	local remote = model:FindFirstChild("GiveLoot", true)
	if remote then
		remote:FireServer()
	end
end

local function scan()
	for _,folder in ipairs(folders) do
		for _,model in ipairs(folder:GetChildren()) do
			if model:IsA("Model") then
				tpAndLoot(model)
				task.wait(0.05)
			end
		end
	end
end


-- SERVER HOP FUNCTION
local function serverHop()

	local PlaceID = game.PlaceId
	local JobID = game.JobId

	local servers = HttpService:JSONDecode(
		game:HttpGet("https://games.roblox.com/v1/games/"..PlaceID.."/servers/Public?limit=100")
	)

	for _,v in pairs(servers.data) do
		if v.playing < v.maxPlayers and v.id ~= JobID then
			TeleportService:TeleportToPlaceInstance(PlaceID, v.id, player)
			break
		end
	end

end


while true do

	scan()

	task.wait(2)

	local remaining = false

	for _,folder in ipairs(folders) do
		for _,model in ipairs(folder:GetChildren()) do
			if model:IsA("Model") and not processed[model] then
				remaining = true
			end
		end
	end

	if not remaining then
		print("All containers looted → ServerHop")
		serverHop()
		break
	end

end
